# AxiomNode Mobile - Environment Configuration
# Copy this file as dev.properties / stg.properties / prod.properties
# and fill in the values for each environment.
# These files are gitignored; populate from secrets repo.

# Backend (api-gateway edge URL)
# Use gateway domain in stg/prod.
# In local dev, use the local edge gateway (localhost/10.0.2.2).
# Never point to internal service hosts like microservice-*, bff-*, ai-engine, api-gateway.
API_BASE_URL=http://localhost:7005

# Auth mode: dev | firebase
AUTH_MODE=dev

# Firebase client config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Google Sign-In Web Client ID (for backend token verification)
GOOGLE_WEB_CLIENT_ID=

# Android signing (only for release builds)
ANDROID_KEYSTORE_FILE=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

